    <circle class="pulse-ring" cx="130" cy="303" r="40"/>
    <circle class="node-circle" cx="130" cy="303" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(130,303)">
      <circle class="icon-part" cx="0" cy="-4" r="10" fill="none" stroke="#e8a020" stroke-width="1.5"/>
