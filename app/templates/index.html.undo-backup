<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Why PRUTSIM – Circular Infographic</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #0a1f4a;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    font-family: 'Segoe UI', Arial, sans-serif;
  }
  .container {
    width: 100%;
    max-width: 720px;
    padding: 20px 20px 0;
  }

  .feature { cursor: pointer; }

  /* Spoke lines */
  .spoke { transition: stroke-opacity 0.4s, stroke-width 0.4s; }

  /* Node circles */
  .node-circle {
    transition: fill 0.4s;
  }

  /* Label text */
  .node-label { transition: fill 0.4s; }

  /* Pulse ring */
  .pulse-ring {
    fill: none;
    stroke: #e8a020;
    stroke-width: 2.5;
    opacity: 0;
    pointer-events: none;
  }

  @keyframes pulseRing {
    0%   { r: 40; opacity: 0.7; }
    100% { r: 62; opacity: 0; }
  }

  /* Active state styles applied via JS classList */
  .feature.active .node-circle {
    fill: #e8a020;
    stroke: #fff;
    stroke-width: 2.5;
  }
  .feature.active .spoke {
    stroke-opacity: 1 !important;
    stroke-width: 2 !important;
    stroke: #fff !important;
  }
  .feature.active .node-label {
    fill: #ffffff;
    font-weight: 700;
  }
  .feature.active .icon-part {
    stroke: #0e2a5e;
  }
  .feature.active .icon-dot {
    fill: #0e2a5e;
  }
  .feature.active .pulse-ring {
    animation: pulseRing 1.1s ease-out infinite;
  }

  /* Info banner */
  .info-bar {
    width: 100%;
    max-width: 720px;
    padding: 0 20px 24px;
  }
  .info-card {
    background: rgba(14,42,94,0.85);
    border: 1.5px solid rgba(232,160,32,0.5);
    border-radius: 14px;
    padding: 14px 22px;
    display: flex;
    align-items: center;
    gap: 16px;
    min-height: 58px;
    margin-bottom: 14px;
    transition: border-color 0.3s;
  }
  .info-number {
    font-size: 30px;
    font-weight: 900;
    color: #e8a020;
    min-width: 38px;
    line-height: 1;
  }
  .info-text {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    text-align: left;
    line-height: 1.3;
  }

  /* Progress bar */
  .progress-wrap {
    width: 100%;
    height: 3px;
    background: rgba(232,160,32,0.15);
    border-radius: 2px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: #e8a020;
    border-radius: 2px;
    transition: width 0.1s linear;
  }

  /* Dot indicators */
  .dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 14px;
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(232,160,32,0.2);
    border: 1.5px solid rgba(232,160,32,0.45);
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
  }
  .dot.active {
    background: #e8a020;
    transform: scale(1.4);
    border-color: #e8a020;
  }

  /* Controls */
  .controls {
    display: flex;
    gap: 10px;
    justify-content: center;
  }
  .btn {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(232,160,32,0.4);
    color: #e8a020;
    padding: 7px 20px;
    border-radius: 20px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .btn:hover { background: rgba(232,160,32,0.18); border-color: #e8a020; }
  .btn.pause-btn { min-width: 80px; }
</style>
</head>
<body>

<div class="container">
<svg id="mainSvg" width="100%" viewBox="0 0 680 680" xmlns="http://www.w3.org/2000/svg" role="img">
  <title>Why PRUTSIM — circular infographic</title>
  <desc>Nine features of PRUTSIM arranged in a circle around a central logo.</desc>
  <defs>
    <radialGradient id="bggrad" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#1a3a6e"/>
      <stop offset="100%" stop-color="#0a1f4a"/>
    </radialGradient>
    <radialGradient id="centerglow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#e8a020" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#e8a020" stop-opacity="0"/>
    </radialGradient>
  </defs>

  <rect width="680" height="680" fill="url(#bggrad)" rx="16"/>
  <circle cx="340" cy="340" r="260" fill="none" stroke="#ffffff" stroke-width="0.5" stroke-opacity="0.08"/>
  <circle cx="340" cy="340" r="195" fill="none" stroke="#e8a020" stroke-width="0.5" stroke-opacity="0.2"/>
  <circle cx="340" cy="340" r="80" fill="none" stroke="#e8a020" stroke-width="0.8" stroke-opacity="0.3"/>
  <circle cx="340" cy="340" r="100" fill="url(#centerglow)"/>
  <circle cx="340" cy="340" r="72" fill="#0e2a5e" stroke="#e8a020" stroke-width="2"/>
  <text x="340" y="330" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-weight="700" font-size="14" fill="#ffffff">WHY</text>
  <text x="340" y="352" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-weight="900" font-size="18" fill="#e8a020">PRUTSIM</text>

  <!-- Feature 1: 100% Placement Assistance -->
  <g class="feature" id="f0" data-label="100% Placement Assistance" onclick="activateFeature(0)">
    <line class="spoke" x1="340" y1="268" x2="340" y2="148" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="340" cy="110" r="40"/>
    <circle class="node-circle" cx="340" cy="110" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(340,110)">
      <rect class="icon-part" x="-13" y="-8" width="26" height="18" rx="3" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path class="icon-part" d="M-7,-8 L-7,-12 Q-7,-14 -5,-14 L5,-14 Q7,-14 7,-12 L7,-8" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <line class="icon-part" x1="-13" y1="-1" x2="13" y2="-1" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-dot" cx="4" cy="-1" r="2.5" fill="#e8a020" stroke="none"/>
    </g>
    <text class="node-label" x="340" y="161" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">100% Placement</text>
    <text class="node-label" x="340" y="173" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Assistance</text>
  </g>

  <!-- Feature 2: Industry-Driven Curriculum -->
  <g class="feature" id="f1" data-label="Industry-Driven Curriculum" onclick="activateFeature(1)">
    <line class="spoke" x1="390" y1="291" x2="461" y2="187" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="475" cy="163" r="40"/>
    <circle class="node-circle" cx="475" cy="163" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(475,163)">
      <rect class="icon-part" x="-10" y="-14" width="20" height="22" rx="2" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line class="icon-part" x1="-6" y1="-8" x2="2" y2="-8" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-6" y1="-3" x2="6" y2="-3" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-6" y1="2" x2="4" y2="2" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-part" cx="7" cy="6" r="5" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-dot" cx="7" cy="6" r="2" fill="#e8a020" stroke="none"/>
    </g>
    <text class="node-label" x="475" y="213" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Industry-Driven</text>
    <text class="node-label" x="475" y="225" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Curriculum</text>
  </g>

  <!-- Feature 3: Experienced Faculty -->
  <g class="feature" id="f2" data-label="Experienced Faculty" onclick="activateFeature(2)">
    <line class="spoke" x1="412" y1="332" x2="513" y2="311" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="550" cy="303" r="40"/>
    <circle class="node-circle" cx="550" cy="303" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(550,303)">
      <rect class="icon-part" x="-12" y="-14" width="18" height="12" rx="2" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line class="icon-part" x1="3" y1="-14" x2="3" y2="-18" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-3" y1="-18" x2="9" y2="-18" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-part" cx="-5" cy="4" r="4" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-5" y1="8" x2="-5" y2="14" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-5" y1="14" x2="-9" y2="18" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-5" y1="14" x2="-1" y2="18" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-9" y1="10" x2="-1" y2="10" stroke="#e8a020" stroke-width="1.5"/>
    </g>
    <text class="node-label" x="550" y="353" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Experienced</text>
    <text class="node-label" x="550" y="365" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Faculty</text>
  </g>

  <!-- Feature 4: Live Projects & Internships -->
  <g class="feature" id="f3" data-label="Live Projects &amp; Internships" onclick="activateFeature(3)">
    <line class="spoke" x1="404" y1="368" x2="492" y2="422" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="516" cy="452" r="40"/>
    <circle class="node-circle" cx="516" cy="452" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(516,452)">
      <rect class="icon-part" x="-14" y="-12" width="28" height="18" rx="2" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line class="icon-part" x1="-18" y1="6" x2="18" y2="6" stroke="#e8a020" stroke-width="1.5"/>
      <polyline class="icon-part" points="-8,0 -3,-6 3,-1 8,-8" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </g>
    <text class="node-label" x="516" y="502" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Live Projects &amp;</text>
    <text class="node-label" x="516" y="514" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Internships</text>
  </g>

  <!-- Feature 5: State-of-the-Art Campus -->
  <g class="feature" id="f4" data-label="State-of-the-Art Campus" onclick="activateFeature(4)">
    <line class="spoke" x1="360" y1="408" x2="388" y2="510" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="393" cy="546" r="40"/>
    <circle class="node-circle" cx="393" cy="546" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(393,546)">
      <rect class="icon-part" x="-14" y="-12" width="28" height="24" rx="1" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <rect class="icon-part" x="-6" y="-6" width="5" height="5" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <rect class="icon-part" x="1" y="-6" width="5" height="5" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <rect class="icon-part" x="-6" y="2" width="5" height="5" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <rect class="icon-part" x="1" y="2" width="5" height="5" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <rect class="icon-part" x="-4" y="9" width="8" height="3" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="0" y1="-12" x2="0" y2="-18" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-3" y1="-15" x2="3" y2="-15" stroke="#e8a020" stroke-width="1.5"/>
    </g>
    <text class="node-label" x="393" y="596" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">State-of-the-Art</text>
    <text class="node-label" x="393" y="608" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Campus</text>
  </g>

  <!-- Feature 6: Alumni Network & Mentorship -->
  <g class="feature" id="f5" data-label="Alumni Network &amp; Mentorship" onclick="activateFeature(5)">
    <line class="spoke" x1="320" y1="408" x2="292" y2="510" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="287" cy="546" r="40"/>
    <circle class="node-circle" cx="287" cy="546" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(287,546)">
      <circle class="icon-part" cx="0" cy="-4" r="5" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-part" cx="-11" cy="8" r="4" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <circle class="icon-part" cx="11" cy="8" r="4" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-4" y1="0" x2="-9" y2="5" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="4" y1="0" x2="9" y2="5" stroke="#e8a020" stroke-width="1.5"/>
      <path class="icon-part" d="M-4,1 Q0,6 4,1" fill="none" stroke="#e8a020" stroke-width="1.5"/>
    </g>
    <text class="node-label" x="287" y="596" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Alumni Network</text>
    <text class="node-label" x="287" y="608" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">&amp; Mentorship</text>
  </g>

  <!-- Feature 7: Cutting-Edge Research -->
  <g class="feature" id="f6" data-label="Cutting-Edge Research" onclick="activateFeature(6)">
    <line class="spoke" x1="276" y1="368" x2="188" y2="422" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="164" cy="452" r="40"/>
    <circle class="node-circle" cx="164" cy="452" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(164,452)">
      <line class="icon-part" x1="-8" y1="12" x2="8" y2="12" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <line class="icon-part" x1="0" y1="12" x2="0" y2="4" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <ellipse class="icon-part" cx="0" cy="-2" rx="4" ry="6" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="0" y1="-8" x2="0" y2="-14" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <line class="icon-part" x1="-4" y1="-14" x2="4" y2="-14" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <path class="icon-part" d="M4,-10 Q10,-8 10,0" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
    </g>
    <text class="node-label" x="164" y="502" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Cutting-Edge</text>
    <text class="node-label" x="164" y="514" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Research</text>
  </g>

  <!-- Feature 8: Global Corporate Tie-Ups -->
  <g class="feature" id="f7" data-label="Global Corporate Tie-Ups" onclick="activateFeature(7)">
