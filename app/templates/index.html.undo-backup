    <text class="node-label" x="130" y="353" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Global Corporate</text>
    <text class="node-label" x="130" y="365" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Tie-Ups</text>
  </g>

  <!-- Feature 9: Leadership & Entrepreneurship Training -->
  <g class="feature" id="f8" data-label="Leadership &amp; Entrepreneurship Training" onclick="activateFeature(8)">
    <line class="spoke" x1="290" y1="291" x2="219" y2="187" stroke="#e8a020" stroke-width="0.6" stroke-opacity="0.35"/>
    <circle class="pulse-ring" cx="205" cy="163" r="40"/>
    <circle class="node-circle" cx="205" cy="163" r="38" fill="#0e2a5e" stroke="#e8a020" stroke-width="1.5"/>
    <g transform="translate(205,163)">
      <circle class="icon-part" cx="4" cy="-10" r="6" fill="none" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="4" y1="-4" x2="4" y2="2" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <line class="icon-part" x1="1" y1="2" x2="7" y2="2" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
      <path class="icon-part" d="M-8,-2 Q-10,4 -6,6 L6,6 L6,10 L-6,10" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <line class="icon-part" x1="-6" y1="10" x2="6" y2="10" stroke="#e8a020" stroke-width="1.5"/>
      <line class="icon-part" x1="-6" y1="13" x2="6" y2="13" stroke="#e8a020" stroke-width="1.5"/>
    </g>
    <text class="node-label" x="205" y="213" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Leadership &amp;</text>
    <text class="node-label" x="205" y="225" text-anchor="middle" font-family="'Segoe UI',Arial,sans-serif" font-size="10.5" font-weight="600" fill="#e8a020">Entrepreneurship</text>
  </g>

</svg>
</div>

<!-- Info Bar -->
<div class="info-bar">
  <div class="progress-wrap"><div class="progress-bar" id="progressBar" style="width:0%"></div></div>
  <div class="info-card">
    <div class="info-number" id="infoNum">1</div>
    <div class="info-text" id="infoText">100% Placement Assistance</div>
  </div>
  <div class="dots" id="dotsContainer"></div>
  <div class="controls">
    <button class="btn" onclick="stepFeature(-1)">◀ Prev</button>
    <button class="btn pause-btn" id="pauseBtn" onclick="togglePause()">⏸ Pause</button>
    <button class="btn" onclick="stepFeature(1)">Next ▶</button>
  </div>
</div>

<script>
  const INTERVAL = 2200;   // ms per feature
  const TOTAL = 9;

  const features = document.querySelectorAll('.feature');
  const labels   = Array.from(features).map(f => f.dataset.label);
  const dotsWrap = document.getElementById('dotsContainer');
  const progressBar = document.getElementById('progressBar');

  let current = 0;
  let paused  = false;
  let startTs = null;
  let rafId   = null;

  // Build dot indicators
  labels.forEach((_, i) => {
    const d = document.createElement('div');
    d.className = 'dot';
    d.onclick = () => { activateFeature(i); if (!paused) restartAnim(); };
    dotsWrap.appendChild(d);
  });

  function activateFeature(idx) {
    features.forEach(f => f.classList.remove('active'));
    dotsWrap.querySelectorAll('.dot').forEach(d => d.classList.remove('active'));
    features[idx].classList.add('active');
    dotsWrap.children[idx].classList.add('active');
    document.getElementById('infoNum').textContent  = idx + 1;
    document.getElementById('infoText').textContent = labels[idx];
    current = idx;
  }

  function stepFeature(dir) {
    activateFeature((current + dir + TOTAL) % TOTAL);
    if (!paused) restartAnim();
  }

  function togglePause() {
    paused = !paused;
    document.getElementById('pauseBtn').textContent = paused ? '▶ Play' : '⏸ Pause';
    if (paused) {
      cancelAnimationFrame(rafId);
      progressBar.style.width = '0%';
    } else {
      restartAnim();
    }
  }

  function restartAnim() {
    cancelAnimationFrame(rafId);
    startTs = null;
    tick();
  }

  function tick(ts) {
    if (!startTs) startTs = ts || performance.now();
    const elapsed = (ts || performance.now()) - startTs;
    const pct = Math.min(elapsed / INTERVAL * 100, 100);
    progressBar.style.width = pct + '%';

    if (elapsed >= INTERVAL) {
      activateFeature((current + 1) % TOTAL);
      startTs = null;
    }
    rafId = requestAnimationFrame(tick);
  }

  // Kick off
  activateFeature(0);
  restartAnim();
</script>
</body>
</html>
