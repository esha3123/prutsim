      <line class="icon-part" x1="-10" y1="-4" x2="10" y2="-4" stroke="#e8a020" stroke-width="1.5"/>
      <path class="icon-part" d="M-7,5 Q-3,9 3,9 Q6,9 7,5" fill="none" stroke="#e8a020" stroke-width="1.5" stroke-linecap="round"/>
